# SolIntent — FastAPI service env
# copy to api/.env before starting uvicorn

# Anthropic — used by the NLP intent parser
# get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Helius — solana rpc with healthier rate limits than public devnet
HELIUS_API_KEY=
SOLINTENT_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_KEY

# Jupiter — quote API for swap routing
JUPITER_API_URL=https://quote-api.jup.ag/v6

# Pyth Hermes — price snapshots used for confirm/preview
PYTH_HERMES_URL=https://hermes.pyth.network

# server runtime
SOLINTENT_PORT=8000
SOLINTENT_LOG_LEVEL=info
