# SolIntent — FastAPI service env
# copy to api/.env before starting uvicorn (uvicorn main:app --port 8010)
# on railway PORT is injected; start command is set in Procfile

# ── claude (intent parser) ──
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ── solana ──
ANCHOR_PROVIDER_URL=https://devnet.helius-rpc.com/?api-key=YOUR_KEY
PROGRAM_ID=AHvsBUGTcXewYD3hyE2F2HunXGszJRJ3k1BCAFwoqCk1

# crank wallet (server-side signer for agent deploy + execute)
# pick ONE: inline JSON for railway, or filesystem path for local dev
CRANK_KEYPAIR_JSON=
ANCHOR_WALLET=~/.config/solana/id.json

# ── crank job auth (block execution endpoint) ──
CRANK_SECRET=

# ── cors ──
# comma-separated list of allowed origins; in prod set this to your vercel URL or '*'
CORS_ORIGINS=http://localhost:5180,http://localhost:3000

# ── extra integrations (kept for reference) ──
HELIUS_API_KEY=
JUPITER_API_URL=https://quote-api.jup.ag/v6
PYTH_HERMES_URL=https://hermes.pyth.network
